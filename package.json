{
  "name": "neon",
  "version": "1.0.0",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "docker:down": "docker compose down",
    "docker:up": "docker compose up -d",
    "start": "node --loader ts-node/esm node-service/app.js",
    "start:node": "node --loader ts-node/esm --env-file=.env node-service/app.js",
    "start:python": "python python-service/run.py",
    "stop:ports": "fuser -k 3000/tcp || true",
    "start:all": "npm run stop:ports && npm run docker:down && npm run docker:up && echo 'Esperando a Mongo...' && sleep 5 && npm run seed && npm run start:node",
    "dev": "node --loader ts-node/esm --env-file=.env node-service/app.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "seed": "node --loader ts-node/esm --env-file=.env node-service/Infrastructure/Database/Seed.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/armandomariscal/neon.git"
  },
  "keywords": [
    "nodejs",
    "backend",
    "ddd",
    "cyberpunk",
    "retro-gaming"
  ],
  "author": "Armando Mariscal",
  "license": "ISC",
  "devDependencies": {
    "@types/mongodb": "^4.0.6",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "mongodb": "^7.1.0"
  }
}
